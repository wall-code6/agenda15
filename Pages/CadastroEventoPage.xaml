<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CadastroEventosMaui.Pages.CadastroEventoPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Cadastro de Evento">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14">

            <Label
                Text="Cadastro de Eventos"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalOptions="Center" />

            <Label Text="Nome do evento" />
            <Entry
                Placeholder="Ex: Festa de Aniversario"
                Text="{Binding NomeEvento, Mode=TwoWay}" />

            <Label Text="Data de início" />
            <DatePicker Date="{Binding DataInicio, Mode=TwoWay}" />

            <Label Text="Data de término" />
            <DatePicker Date="{Binding DataTermino, Mode=TwoWay}" />

            <Label Text="Número de participantes" />
            <Entry
                Placeholder="Ex: 50"
                Keyboard="Numeric"
                Text="{Binding NumeroParticipantes, Mode=TwoWay}" />

            <Label Text="Local do evento" />
            <Entry
                Placeholder="Ex: São Paulo - SP"
                Text="{Binding LocalEvento, Mode=TwoWay}" />

            <Label Text="Custo por participante" />
            <Entry
                Placeholder="Ex: 120,00"
                Keyboard="Numeric"
                Text="{Binding CustoPorParticipante, Mode=TwoWay}" />

            <Border Padding="14" BackgroundColor="#1c1f1d">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Prévia" FontAttributes="Bold" FontSize="18" />
                    <Label Text="{Binding TextoDuracao, StringFormat='Duração: {0}'}" />
                    <Label Text="{Binding CustoTotal, StringFormat='Custo total: R$ {0:F2}'}" />
                </VerticalStackLayout>
            </Border>

            <Button
                Text="Finalizar Cadastro"
                Clicked="OnFinalizarCadastroClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

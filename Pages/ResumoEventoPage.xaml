<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CadastroEventosMaui.Pages.ResumoEventoPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Resumo do Evento">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <Label
                Text="Resumo do Evento"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalOptions="Center" />

            <Border Padding="18" BackgroundColor="#1c1f1d">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding NomeEvento}" FontSize="22" FontAttributes="Bold" />
                    <Label Text="{Binding DataInicio, StringFormat='Data de início: {0:dd/MM/yyyy}'}" />
                    <Label Text="{Binding DataTermino, StringFormat='Data de término: {0:dd/MM/yyyy}'}" />
                    <Label Text="{Binding TextoDuracao, StringFormat='Duração do evento: {0}'}" />
                    <Label Text="{Binding NumeroParticipantes, StringFormat='Participantes: {0}'}" />
                    <Label Text="{Binding LocalEvento, StringFormat='Local: {0}'}" />
                    <Label Text="{Binding CustoPorParticipante, StringFormat='Custo por participante: R$ {0:F2}'}" />
                    <Label
                        Text="{Binding CustoTotal, StringFormat='Custo total do evento: R$ {0:F2}'}"
                        FontSize="20"
                        FontAttributes="Bold" />
                </VerticalStackLayout>
            </Border>

            <Button Text="Voltar" Clicked="OnVoltarClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
